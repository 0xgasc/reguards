# Copy this file to .env and fill in your values
# Never commit .env to git

# Database (use either MONGO_URI or MONGODB_URI)
MONGO_URI=mongodb://localhost:27017/reguards
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/reguards

# Authentication
JWT_SECRET=generate-a-strong-random-secret-here

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Blockchain (Base L2) — optional for basic points only
PRIVATE_KEY=your-ethereum-private-key
SPONSOR_PRIVATE_KEY=your-sponsor-wallet-private-key
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org
FACTORY_ADDRESS=your-deployed-factory-contract-address
BASESCAN_API_KEY=your-basescan-api-key
